{
  "name": "lgtm-buzzer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser extension that quizzes you on the diff before letting you approve a PR.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/protocol",
    "packages/core",
    "packages/adapters/*",
    "packages/host",
    "packages/extension",
    "packages/evals"
  ],
  "scripts": {
    "build": "npm run build:libs && npm run build:extension",
    "build:libs": "node scripts/build-libs.mjs",
    "build:extension": "npm run build --workspace=@lgtm-buzzer/extension --if-present",
    "typecheck": "node scripts/build-libs.mjs",
    "typecheck:tests": "node scripts/typecheck-tests.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run build && npm run test && npm run lint && npm run typecheck:tests",
    "clean": "tsc -b --clean",
    "evals": "npm run evals --workspace=@lgtm-buzzer/evals --if-present",
    "evals:quick": "npm run evals:quick --workspace=@lgtm-buzzer/evals --if-present",
    "release": "node scripts/release.mjs",
    "release:build": "node scripts/release.mjs",
    "release:check": "node scripts/release.mjs --skip-check --no-checksums --output-dir tmp/release-test --force",
    "release:clean": "node -e \"const fs=require('fs');['dist'].forEach(d=>{try{fs.rmSync(d,{recursive:true})}catch{}});\""
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
