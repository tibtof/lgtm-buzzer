+package store_test
+
+import (
+	"testing"
+	"errors"
+	"github.com/example/app/internal/store"
+)
+
+func TestGetByID_NilUser(t *testing.T) {
+	t.Parallel()
+	s := store.NewUserStore(newStubDB(nil))
+	_, err := s.GetByID("unknown-id")
+	if !errors.Is(err, store.ErrUserNotFound) {
+		t.Fatalf("expected ErrUserNotFound, got %v", err)
+	}
+}
+
+func TestGetByID_DBError(t *testing.T) {
+	t.Parallel()
+	s := store.NewUserStore(newStubDB(errStub))
+	_, err := s.GetByID("any-id")
+	if err == nil {
+		t.Fatal("expected a db error, got nil")
+	}
+}
