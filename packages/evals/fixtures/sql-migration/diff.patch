diff --git a/migrations/0042_add_audit_columns.up.sql b/migrations/0042_add_audit_columns.up.sql
new file mode 100644
--- /dev/null
+++ b/migrations/0042_add_audit_columns.up.sql
@@ -0,0 +1,14 @@
+-- Migration 0042: Add created_at and updated_at audit columns to the orders table.
+-- created_at is backfilled to the epoch for existing rows.
+-- updated_at defaults to the current timestamp on INSERT and is maintained
+-- by the trigger defined below.
+
+ALTER TABLE orders
+  ADD COLUMN created_at TIMESTAMPTZ NOT NULL DEFAULT '1970-01-01 00:00:00+00',
+  ADD COLUMN updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW();
+
+CREATE OR REPLACE FUNCTION orders_set_updated_at()
+RETURNS TRIGGER LANGUAGE plpgsql AS $$
+BEGIN
+  NEW.updated_at = NOW();
+  RETURN NEW;
+END;
+$$;
+
+CREATE TRIGGER orders_updated_at
+  BEFORE UPDATE ON orders
+  FOR EACH ROW EXECUTE FUNCTION orders_set_updated_at();
diff --git a/migrations/0042_add_audit_columns.down.sql b/migrations/0042_add_audit_columns.down.sql
new file mode 100644
--- /dev/null
+++ b/migrations/0042_add_audit_columns.down.sql
@@ -0,0 +1,6 @@
+-- Rollback for migration 0042.
+DROP TRIGGER IF EXISTS orders_updated_at ON orders;
+DROP FUNCTION IF EXISTS orders_set_updated_at();
+
+ALTER TABLE orders
+  DROP COLUMN IF EXISTS created_at,
+  DROP COLUMN IF EXISTS updated_at;
