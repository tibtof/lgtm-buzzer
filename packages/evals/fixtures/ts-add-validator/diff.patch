+import { describe, it, expect } from "vitest";
+import { validateEmail, MAX_EMAIL_LENGTH } from "./email.js";
+
+describe("validateEmail", () => {
+  it("returns Right for a valid email", () => {
+    const result = validateEmail("User@Example.COM");
+    expect(result.isRight()).toBe(true);
+    result.fold(
+      () => {},
+      (email) => expect(email).toBe("user@example.com"),
+    );
+  });
+
+  it("returns Left.empty for blank input", () => {
+    const result = validateEmail("   ");
+    expect(result.isLeft()).toBe(true);
+    result.fold((err) => expect(err.kind).toBe("empty"), () => {});
+  });
+
+  it("returns Left.too-long when length exceeds MAX_EMAIL_LENGTH", () => {
+    const long = "a".repeat(MAX_EMAIL_LENGTH) + "@x.co";
+    const result = validateEmail(long);
+    expect(result.isLeft()).toBe(true);
+    result.fold(
+      (err) => expect(err.kind).toBe("too-long"),
+      () => {},
+    );
+  });
+});
